# RailRide - Root environment reference
# Copy backend/.env.example to backend/.env for API configuration

# API
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
DATABASE_URL=postgresql+asyncpg://railride:railride_secret@localhost:5432/railride
REDIS_URL=redis://localhost:6379/0

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# AWS (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=railride-assets
AWS_REGION=ap-south-1
