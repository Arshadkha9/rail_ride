# Application
APP_NAME=RailRide
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://railride:railride_secret@db:5432/railride
DATABASE_URL_SYNC=postgresql://railride:railride_secret@db:5432/railride

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Railway API (mock)
RAILWAY_API_BASE_URL=https://api.railway.example.com
RAILWAY_API_KEY=mock-railway-api-key

# Ride pricing (per km)
FARE_BIKE_PER_KM=8.0
FARE_AUTO_PER_KM=12.0
FARE_TAXI_PER_KM=18.0
BASE_FARE_BIKE=15.0
BASE_FARE_AUTO=25.0
BASE_FARE_TAXI=40.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
